rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only this email can write — anyone can read
    function isOwner() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email == 'david@prismism.com';
    }

    match /use_cases/{docId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /suggestion_queue/{docId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /suggestion_sessions/{docId} {
      allow read, write: if false;
    }

    match /meta/{docId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /use_case_groups/{docId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
